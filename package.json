{
  "name": "reelkeeper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A client-only PWA to save, organize, and map Instagram reels.",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "dev": "vite",
    "build": "npm run icons && tsc --noEmit && vite build",
    "postbuild": "cp dist/index.html dist/404.html",
    "preview": "vite preview"
  },
  "dependencies": {
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  }
}
